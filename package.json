{
  "name": "bladderdiary-patient",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "e2e:walkthrough": "playwright test --config=playwright.config.ts && node scripts/update-walkthrough-findings.mjs",
    "e2e:walkthrough:headed": "HEADED=1 playwright test --config=playwright.config.ts --headed",
    "e2e:walkthrough:daily": "bash scripts/daily-walkthrough.sh",
    "e2e:walkthrough:locales": "playwright test --project=en --project=fr --project=es --project=pt --project=zh --project=ar --config=playwright.config.ts",
    "e2e:walkthrough:deep": "playwright test --project=deep-flow --config=playwright.config.ts",
    "e2e:walkthrough:a11y": "playwright test --project=a11y --config=playwright.config.ts"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.0",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.0.1",
    "pdf-parse": "^2.4.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
